        Category clothing = new Category();
        clothing.setName("服装鞋帽");
        clothing.setDescription("时尚服装和鞋帽");
        clothing.setIconUrl("/icons/clothing.png");
        clothing.setSortOrder(2);
        clothing.setParentId(null);
        clothing.setLevel(1);
