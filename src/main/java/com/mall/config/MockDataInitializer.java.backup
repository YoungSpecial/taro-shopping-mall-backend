    private void initializeCategories(CategoryRepository repository) {
        Category electronics = new Category();
        electronics.setName("电子产品");
        electronics.setDescription("各类电子数码产品");
        electronics.setIconUrl("/icons/electronics.png");
        electronics.setSortOrder(1);
        electronics.setParentId(null);
        electronics.setLevel(1);
